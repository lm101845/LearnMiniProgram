<!--pages/text/text.wxml-->
<!-- <text>pages/text/text.wxml</text> -->

<!-- 1.基本使用 -->
<text>Hello World</text>
<text>你好小程序</text>
<!-- 写上\n就可以换行了 -->
<text>你好小程序\n</text>
<text>你好小程序\n</text>

<!-- 2. selectable:true-->
<!-- 现在这个属性现在已经废弃了 -->
<!-- 在模拟器上是不可选中的，但是在真机上是可以选中的 -->
<!-- 默认情况下text中的文本长按是不能选中的 -->
<text selectable="true">Hello Coderwhy\n</text>
<text selectable="{{true}}">Hello Coderwhy\n</text>
<!-- 赋值的话一定要用胡子语法，否则就相当于把字符串给它赋值过去了 -->
<text selectable>Hello Coderwhy\n</text>
<!-- 直接这样写也行，写了这个属性就表示为true -->

<!-- 3.space：决定文本空格大小 -->
<text>Hello World\n</text>
<text space="nbsp">Hello World\n</text>
<!-- 前2个是一样的 -->
<text space="emsp">Hello World\n</text>
<!-- m表示max -->
<!-- emsp:一个中文字符大小 -->
<text space="ensp">Hello World\n</text>
<!-- n表示min -->
<!-- ensp:半个中文字符大小 -->

<!-- 4.decode属性：是否解码文本 -->
<text>5 &gt; 3\n</text>
<text decode>5 &gt; 3</text>



