<!--pages/image/image.wxml-->
<!-- <text>pages/image/image.wxml</text> -->

<!-- 1.image的基本使用 -->
<!-- 
  重点：
      1.image组件可以写成单标签，也可以写成双标签(后面要添加一个/)
      2.image组件默认有自己的大小(320*240)
      3.image组件是一个行内块元素(inline-block)

 -->
 <image/>
 <text>哈哈哈</text>

 <!-- 2.src：本地路径(相对/绝对)/远程地址 -->
 <image src="../../assets/小猫.png"/>
 <!-- 这是相对路径的写法 -->
 <image src="/assets/小猫.png"/>
 <!-- 这是绝对路径的写法 -->
 <image src="https://res.wx.qq.com/wxdoc/dist/assets/img/0.4cb08bb4.jpg"/>

 <!-- 补充：相册中的图片-->
 <button bindtap="handleChooseAlbum">选中图片</button>
 <image src="{{imagePath}}"/>

 <!-- 3.bindload：监听图片加载完成 -->
 <!-- lazy-load:图片的懒加载 -->
 <view>---------------------------------------</view>
 <image wx:for="{{10}}" src="https://res.wx.qq.com/wxdoc/dist/assets/img/0.4cb08bb4.jpg" bindload="handleImageLoad" lazy-load/>

 <!-- 4.show-menu-by-longpress： 长按图片出现小程序码 -->
<image show-menu-by-longpress src="https://res.wx.qq.com/wxdoc/dist/assets/img/0.4cb08bb4.jpg"/>

