
<!-- 1.事件处理的回顾 -->
<button bindtap="handleBtnClick" size="mini">按钮</button>
<button bind:tap="handleBtnClick" size="mini">按钮</button>
<!-- bindtap和bind:tap是没有任何区别的 -->
<button catch:tap="handleBtnClick" size="mini">按钮</button>

<!-- 2.常见的一些事件 -->
<view class="box" 
 bind:touchstart="handleTouchStart"
 bind:touchmove="handleTouchMove"
 bind:touchend="handleTouchEnd"
 bind:tap="handleTap"
 bind:longpress="handleLongPress"></view>

 <!-- 3.事件对象分析 -->
<button size="mini" 
        id="btn" 
        bindtap="handleEventClick"
        bindtouchend="handleEventEnd">事件对象</button>

<!-- 4.事件参数的传递 -->
<view class="outer" id="outer" bindtap="handleOuter">外层的view
  <view class="inner" bindtap="handleInner" id="inner">内层的view</view>
</view>

<view class="container">
  <block wx:for="{{titles}}" wx:key="index">
    <view class="item" 
          bindtap="handleItemClick"
          data-index="{{index}}"
          data-item="{{item}}">{{item}}</view>
  </block>
</view>

<!-- 5.事件冒泡和事件捕获：catch和bind的区别-->
<!-- bind会一层层传递 -->
<!-- catch:会阻止时间段额进一步传递 -->
<view class="view1" capture-bind:tap="handleCaptureView1" bindtap="handleBindView1">
<!-- <view class="view1" capture-catch:tap="handleCaptureView1" bindtap="handleBindView1"> -->
  <!-- <view class="view2" capture-bind:tap="handleCaptureView2" bindtap="handleBindView2"> -->
  <view class="view2" capture-bind:tap="handleCaptureView2" catchtap="handleBindView2">
    <view class="view3" capture-bind:tap="handleCaptureView3" bindtap="handleBindView3"></view>
  </view>
</view>